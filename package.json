{
  "name": "reticulum-js-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present && npm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "types": "npm run types --workspaces --if-present",
    "format": "npx @biomejs/biome check --use-editorconfig=true --write packages/*/src packages/*/test examples scripts",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@ably/msgpack-js": "^0.4.1",
    "@digitaldefiance/bzip2-wasm": "^1.1.1",
    "@types/node": "^26.1.0",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3"
  }
}
