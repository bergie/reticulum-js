{
  "name": "reticulum-js",
  "version": "0.1.0",
  "description": "Reticulum Network System for JavaScript",
  "keywords": [
    "reticulum",
    "rns",
    "mesh"
  ],
  "license": "EUPL-1.2",
  "author": "Henri Bergius <henri.bergius@iki.fi>",
  "type": "module",
  "main": "src/index.js",
  "types": "types/src/index.d.ts",
  "scripts": {
    "docs": "npx typedoc",
    "lint": "npx @biomejs/biome check --use-editorconfig=true src/",
    "format": "npx @biomejs/biome check --use-editorconfig=true --write src/ test/ examples/",
    "types": "npx tsc",
    "test": "node --test --test-force-exit --test-timeout 5000 test/*.js test/**/*.js",
    "preversion": "npm run types"
  },
  "devDependencies": {
    "@ably/msgpack-js": "^0.4.1",
    "@digitaldefiance/bzip2-wasm": "^1.1.1",
    "@types/node": "^26.1.0",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3"
  }
}
