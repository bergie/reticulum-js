  "types": "types/src/index.d.ts",
  "files": [
    "src",
    "types"
  ],
  "dependencies": {
    "reticulum-js": "^0.3.0",
    "ws": "^8.18.0"
  },
  "scripts": {
    "test": "node --test --test-force-exit --test-timeout 5000 test/*.js test/**/*.js",
    "lint": "npx @biomejs/biome check --use-editorconfig=true src/",
